[init]
	defaultBranch = main

[user]
	name = someone
	email = someone@someone

[core]
	compression = 9
	whitespace = error
	preloadindex = true

[advice]
	addEmptyPathspec = false
	pushNonFastForward = false
	statusHints = false

[push]
	autoSetupRemote = true

[url "git@github.com:"]
	insteadOf = "gh:"
